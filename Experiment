from openai import OpenAI

client = OpenAI(api_key="YOUR_API_KEY")

#Single prompt 
response = client.responses.create(
    model="gpt-5.3",
    input="Explain recursion in one sentence."
)

print(response.output[0].content[0].text)

#Multiple prompts
prompts = [
    "Explain recursion in one sentence.",
    "Explain recursion like I'm 5.",
    "Give a Python example of recursion."
]

for p in prompts:
    response = client.responses.create(
        model="gpt-5.3",
        input=p
    
    print("PROMPT:", p)
    print("OUTPUT:", response.output[0].content[0].text)
    print("-" * 50)

